<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eco Kids - Comunicação Assistiva</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>Eco Kids <span>🍃</span></h1>
        <p>Clique no ícone para falar</p>
    </header>

    <main id="board">
        <div class="card" onclick="falar('Eu quero comer')">
            <span class="emoji">🍎</span>
            <p>Comer</p>
        </div>

        <div class="card" onclick="falar('Eu quero beber água')">
            <span class="emoji">💧</span>
            <p>Beber</p>
        </div>

        <div class="card" onclick="falar('Eu quero ir ao banheiro')">
            <span class="emoji">🧻</span>
            <p>Banheiro</p>
        </div>

        <div class="card" onclick="falar('Estou com sono')">
            <span class="emoji">😴</span>
            <p>Sono</p>
        </div>

        <div class="card" onclick="falar('Estou feliz')">
            <span class="emoji">😊</span>
            <p>Feliz</p>
        </div>

        <div class="card" onclick="falar('Estou triste')">
            <span class="emoji">😢</span>
            <p>Triste</p>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>